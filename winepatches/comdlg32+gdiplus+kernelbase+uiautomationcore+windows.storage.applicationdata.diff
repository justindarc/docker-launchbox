 static HRESULT WINAPI application_data_get_LocalFolder( IApplicationData *iface, IStorageFolder **value )
 {
-    FIXME( "iface %p, value %p stub!\n", iface, value );
-    return E_NOTIMPL;
+    WCHAR path[MAX_PATH], app[MAX_PATH];
+    DWORD len;
+
+    TRACE( "iface %p, value %p\n", iface, value );
+
+    if (!value) return E_INVALIDARG;
+
+    /* Use %LOCALAPPDATA%\Packages\<ExeName> as the local folder.
+     * On a real packaged Windows app this would be the per-package
+     * container; for identity-less Win32 apps running under Wine we
+     * derive the container name from the executable basename so that
+     * different apps get isolated storage. */
+    len = GetEnvironmentVariableW( L"LOCALAPPDATA", path, MAX_PATH );
+    if (!len || len >= MAX_PATH) return E_UNEXPECTED;
+
+    if (!get_app_name( app, MAX_PATH )) return E_UNEXPECTED;
+
+    if (wcslen( path ) + 1 + wcslen( L"Packages\\" ) + wcslen( app ) >= MAX_PATH)
+        return E_UNEXPECTED;
+
+    wcscat( path, L"\\Packages\\" );
+    wcscat( path, app );
+
+    return create_local_folder( path, value );
 }
 
