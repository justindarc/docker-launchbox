+/* Get the running executable's basename without extension, e.g. "MyApp"
+ * from "C:\path\to\MyApp.exe".  This is used as the per-application
+ * container name under %LOCALAPPDATA%\Packages\ so that different apps get
+ * isolated storage, mirroring what Windows does for packaged apps. */
+static BOOL get_app_name( WCHAR *buf, DWORD buflen )
+{
+    WCHAR exe[MAX_PATH];
+    const WCHAR *base, *dot;
+    SIZE_T name_len;
+
+    if (!GetModuleFileNameW( NULL, exe, MAX_PATH )) return FALSE;
+
+    /* Find the basename: last backslash component */
+    base = wcsrchr( exe, '\\' );
+    base = base ? base + 1 : exe;
+
+    /* Strip the extension if present */
+    dot = wcsrchr( base, '.' );
+    name_len = dot ? (SIZE_T)(dot - base) : wcslen( base );
+
+    if (name_len == 0 || name_len >= buflen) return FALSE;
+
+    memcpy( buf, base, name_len * sizeof(WCHAR) );
+    buf[name_len] = 0;
+    return TRUE;
+}
