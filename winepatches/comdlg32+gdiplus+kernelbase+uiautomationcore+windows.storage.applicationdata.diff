+static HRESULT create_local_folder( const WCHAR *path, IStorageFolder **out )
+{
+    struct storage_folder *impl;
+
+    if (!out) return E_INVALIDARG;
+    if (!(impl = calloc( 1, sizeof(*impl) ))) return E_OUTOFMEMORY;
+
+    impl->IStorageFolder_iface.lpVtbl = &storage_folder_vtbl;
+    impl->IStorageItem_iface.lpVtbl   = &storage_item_vtbl;
+    impl->ref = 1;
+    lstrcpynW( impl->path, path, MAX_PATH );
+
+    /* Ensure the directory exists (create intermediate dirs manually) */
+    {
+        WCHAR tmp[MAX_PATH];
+        WCHAR *p;
+        lstrcpyW( tmp, path );
+        for (p = tmp + 1; *p; p++)
+        {
+            if (*p == '\\')
+            {
+                *p = 0;
+                CreateDirectoryW( tmp, NULL );
+                *p = '\\';
+            }
+        }
+        CreateDirectoryW( tmp, NULL );
+    }
+
+    *out = &impl->IStorageFolder_iface;
+    TRACE( "created IStorageFolder %p for path %s.\n", *out, debugstr_w( path ) );
+    return S_OK;
+}
