@@ -3536,6 +3536,25 @@ static HRESULT WINAPI IExplorerBrowserEvents_fnOnNavigationComplete(IExplorerBro
         This->psi_folder = NULL;
     }
 
+    /* When picking folders, navigating to a folder via the left-hand navigation
+     * tree selects that folder as the current result.  The right-pane shell view
+     * fires CDBOSC_SELCHANGE which triggers fill_filename_from_selection, but
+     * that only covers items explicitly selected inside the view.  Navigation
+     * driven by the nav-tree (NSTCEvents_fnOnSelectionChanged -> BrowseToObject)
+     * never produces a CDBOSC_SELCHANGE for the destination folder itself, so
+     * the filename textbox is never updated.  Fix this by updating the textbox
+     * directly from the newly-navigated-to folder whenever FOS_PICKFOLDERS is
+     * active. */
+    if((This->options & FOS_PICKFOLDERS) && This->psi_folder)
+    {
+        LPWSTR path = NULL;
+        if(SUCCEEDED(IShellItem_GetDisplayName(This->psi_folder, SIGDN_FILESYSPATH, &path)))
+        {
+            set_file_name(This, path);
+            CoTaskMemFree(path);
+        }
+    }
+
     events_OnFolderChange(This);
 
     return S_OK;
diff --git a/dlls/gdiplus/gdiplus.c b/dlls/gdiplus/gdiplus.c
index 1dbb96349be..28fbe5766dc 100644
--- a/dlls/gdiplus/gdiplus.c
+++ b/dlls/gdiplus/gdiplus.c
@@ -321,6 +321,16 @@ GpStatus hresult_to_status(HRESULT res)
         case E_INVALIDARG:
             return InvalidParameter;
         default:
+            /* Real Windows GDI+ returns OutOfMemory for most failure conditions,
+             * including file-not-found and other I/O errors. This is a well-known
+             * GDI+ quirk that .NET System.Drawing relies on: it translates the
+             * OutOfMemory GDI+ status into a catchable managed exception.
+             * Returning GenericError here instead causes .NET to throw a different
+             * exception type that may not be handled the same way by the CLR,
+             * leading to crashes in applications like ImageDupeGrouper that depend
+             * on this behaviour when image files cannot be opened. */
+            if (HRESULT_FACILITY(res) == FACILITY_WIN32)
+                return OutOfMemory;
             return GenericError;
     }
 }
