@@ -2763,6 +2763,22 @@ HRESULT WINAPI UiaNodeFromHandle(HWND hwnd, HUIANODE *huianode)
 {
     TRACE("(%p, %p)\n", hwnd, huianode);
 
+    /*
+     * When the HWND belongs to the calling thread, return E_NOTIMPL
+     * immediately.  On Wine, the full UIA node creation path for same-
+     * thread HWNDs triggers a chain of COM cross-apartment calls that
+     * deadlock in CoWaitForMultipleHandles (Wine's LRPC dispatch does
+     * not properly handle re-entrant calls to an STA during CoWait).
+     * Returning E_NOTIMPL causes the managed UIAutomationClient to
+     * propagate the failure gracefully — WPF catches it and continues
+     * without accessibility for this element.
+     */
+    if (GetWindowThreadProcessId(hwnd, NULL) == GetCurrentThreadId())
+    {
+        if (huianode) *huianode = NULL;
+        return E_NOTIMPL;
+    }
+
     return create_uia_node_from_hwnd(hwnd, huianode, 0);
 }
 
